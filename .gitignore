# Ignore everything by default
/*

# Keep repository metadata and docs
!.gitignore
!README.md

# Keep only child theme
!wp-content/
wp-content/*
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/syntaxsidekick-child/
!wp-content/themes/syntaxsidekick-child/**

# Ignore build/dependency and environment noise inside tracked themes
wp-content/themes/**/node_modules/
wp-content/themes/**/vendor/
wp-content/themes/**/*.log
wp-content/themes/**/.DS_Store
wp-content/themes/**/Thumbs.db

# Ignore editor metadata
.vscode/
.idea/
*.swp
*.swo
